# =============================================
# SentinelX Environment Configuration
# =============================================
# COPY THIS FILE TO .env BEFORE DEPLOYING!
# If deploying via Docker, MongoDB and ML service URLs are handled automatically.

# ---- Production Security ----
# CHANGE THIS TO A LONG RANDOM STRING IN PRODUCTION!
JWT_SECRET=sentinelx-production-jwt-key-change-me
JWT_EXPIRES_IN=7d

# ---- MongoDB ----
# Keep this as-is if using Docker Compose, otherwise use your Atlas URI
MONGODB_URI=mongodb://mongodb:27017/sentinelx

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# ---- Backend Server ----
PORT=5000
NODE_ENV=production
# Update this to your live domain (e.g. https://sentinelx.io)
FRONTEND_URL=http://localhost:5173

# ---- ML Service ----
# Keep this as-is if using Docker Compose
ML_SERVICE_URL=http://ml-service:8000

# ---- VirusTotal API ----
# Get your free API key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here

# ---- AbuseIPDB API ----
# Get your free API key at: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your-abuseipdb-api-key-here

# ---- IP Geolocation ----
# Using ip-api.com (free, no key needed for non-commercial)
# Or get a key from ipinfo.io: https://ipinfo.io/signup
IPINFO_TOKEN=your-ipinfo-token-here

# ---- WHOIS ----
# Using whoisjsonapi.com (free tier: 1000 req/month)
WHOIS_API_KEY=your-whois-api-key-here

# ---- Admin Seed ----
ADMIN_EMAIL=admin@sentinelx.io
ADMIN_PASSWORD=Admin@SentinelX2026
